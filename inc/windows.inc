; Type sizes (16-bit Windows 1.x):
;   BYTE   = 1     WORD  = 2    DWORD = 4
;   BOOL   = 2     HANDLE= 2    HWND  = 2     HDC = 2
;   LPSTR  = 4     LPVOID= 4    FARPROC = 4
;   WPARAM = 2     LPARAM= 4    LRESULT = 4
; ======================================================================

